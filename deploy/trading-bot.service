[Unit]
Description=GrokEmpire Trading Bot
After=network.target

[Service]
Type=simple
User=trader
WorkingDirectory=/home/trader/grok-empire
Environment=PATH=/home/trader/grok-empire/.venv/bin
ExecStart=/home/trader/grok-empire/.venv/bin/python agents/trading/supervisor.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target